# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ─────────────────────────────────────────────
# Laravel
# ─────────────────────────────────────────────
# Generate with: php artisan key:generate --show
LARAVEL_APP_KEY=base64:CHANGE_ME

# ─────────────────────────────────────────────
# Domains
# ─────────────────────────────────────────────
APP_DOMAIN=ai-ops.jaor13.app
N8N_DOMAIN=n8n.ai-ops.jaor13.app

# ─────────────────────────────────────────────
# n8n
# ─────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=change_me_n8n_password

# ─────────────────────────────────────────────
# AI / External Services
# ─────────────────────────────────────────────
# Chat completions (lead scoring, triage, drafts) run through OpenRouter.
# The API key is entered in the n8n UI as an OpenRouter credential — not required here.
# Free models e.g. meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Embeddings run on the self-hosted Ollama server (VPS 2).
# Use the PRIVATE IP of VPS 2 if both servers share a private network,
# otherwise the public IP locked down by firewall to VPS 1 only.
OLLAMA_HOST=http://VPS2_IP:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─────────────────────────────────────────────
# Timezone
# ─────────────────────────────────────────────
TIMEZONE=Asia/Manila
